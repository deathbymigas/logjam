---
interface Props {
  name?: string;
  id?: string;
  maxlength?: number;
}

const { name = 'message', id = 'message', maxlength = 300 } = Astro.props;
---

<div class="textbox">
  <div class="textbox-label-row">
    <label class="textbox-label" for={id}>get in touch</label>
    <span class="textbox-counter" id={`${id}-counter`}>0/{maxlength}</span>
  </div>
  <textarea
    name={name}
    id={id}
    class="textbox-input"
    maxlength={maxlength}
    required
  ></textarea>
</div>

<script>
  const textareas = document.querySelectorAll<HTMLTextAreaElement>('.textbox-input');
  textareas.forEach((textarea) => {
    const counterId = textarea.id + '-counter';
    const counter = document.getElementById(counterId);
    if (!counter) return;
    const max = parseInt(textarea.getAttribute('maxlength') || '300', 10);

    textarea.addEventListener('input', () => {
      const len = textarea.value.length;
      counter.textContent = `${len}/${max}`;
      if (max - len < 20) {
        counter.classList.add('textbox-counter--limit');
      } else {
        counter.classList.remove('textbox-counter--limit');
      }
    });
  });
</script>

<style>
  .textbox {
    position: relative;
    width: 390px;
    height: 120px;
    background-color: white;
    border: 2px solid var(--color-border);
    display: flex;
    flex-direction: column;
    padding: 8px 10px;
    gap: 4px;
  }

  .textbox::after {
    content: '';
    position: absolute;
    inset: -2px;
    background-image: url('/textures/grain-bg.png');
    background-size: var(--texture-size);
    background-position: top left;
    background-repeat: repeat;
    opacity: 0.53;
    pointer-events: none;
  }

  .textbox-label-row {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }

  .textbox-label {
    font-family: var(--font-ui);
    font-weight: bold;
    font-size: 12px;
    color: var(--color-label);
    text-transform: lowercase;
  }

  .textbox-counter {
    font-family: var(--font-ui);
    font-weight: bold;
    font-size: 12px;
    color: var(--color-char-counter);
    text-transform: lowercase;
  }

  .textbox-counter--limit {
    color: var(--color-error);
  }

  .textbox-input {
    position: relative;
    z-index: 1;
    font-family: var(--font-ui);
    font-weight: bold;
    font-size: 14px;
    color: var(--color-text-primary);
    border: none;
    outline: none;
    background: transparent;
    width: 100%;
    flex: 1;
    resize: none;
    padding: 0;
    line-height: 1.4;
  }

  .textbox-input:focus {
    outline: none;
  }
</style>
