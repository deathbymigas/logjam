---
interface Props {
  state?: 'active' | 'inactive' | 'error';
  name?: string;
  id?: string;
}

const { state = 'inactive', name = 'email', id = 'email' } = Astro.props;

const isError = state === 'error';
---

<div class:list={['field', `field--${state}`]}>
  <div class="field-label-row">
    <label class="field-label" for={id}>your email address</label>
    {isError && <span class="field-error">required</span>}
  </div>
  <input
    type="email"
    name={name}
    id={id}
    class="field-input"
    autocomplete="email"
    required
  />
</div>

<style>
  .field {
    position: relative;
    width: 390px;
    height: 60px;
    background-color: white;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8px 10px;
    gap: 2px;
  }

  .field::after {
    content: '';
    position: absolute;
    inset: -1px;
    background-image: url('/textures/grain-bg.png');
    background-size: var(--texture-size);
    background-position: top left;
    background-repeat: repeat;
    opacity: 0.53;
    pointer-events: none;
  }

  .field--active {
    border-width: 2px;
  }

  .field--active::after,
  .field--error::after {
    inset: -2px;
  }

  .field--error {
    border-width: 2px;
    border-color: var(--color-border-error);
  }

  .field-label-row {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .field-label {
    font-family: var(--font-ui);
    font-weight: bold;
    font-size: 12px;
    color: var(--color-label);
    text-transform: lowercase;
  }

  .field-error {
    font-family: var(--font-ui);
    font-weight: bold;
    font-size: 12px;
    color: var(--color-error);
    text-transform: lowercase;
  }

  .field-input {
    position: relative;
    z-index: 1;
    font-family: var(--font-ui);
    font-weight: bold;
    font-size: 14px;
    color: var(--color-text-primary);
    border: none;
    outline: none;
    background: transparent;
    width: 100%;
    padding: 0;
    caret-color: var(--color-dark);
  }

  .field-input::placeholder {
    color: transparent;
  }

  .field-input:focus {
    outline: none;
  }
</style>
